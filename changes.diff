+
+  it("should apply where conditions for each property in the where object", () => {
+    const args = {
+      first: 10,
+      offset: 0,
+      where: {
+        name: { eq: "test" } as FilterValue,
+        age: { gt: 18 } as FilterValue,
+      },
+    };
+
+    const result = applyWhere<any, any, any>(
+      "test_table" as any,
+      mockQuery as any,
+      args,
+    );
