+import type { WhereArgsType } from "./createEntityWhereArgs.js";
+
+export type BaseQueryArgsType<
+  TWhereInput extends object,
+  TSortOptions extends SortOptions<EntityFields>,
+> = {
+  first?: number;
+  offset?: number;
+  where?: TWhereInput;
+  sortBy?: TSortOptions;
