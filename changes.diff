+    expect(Object.keys(instance)).toContain("chain_id");
+  });
+
+  it("should create sort options for primitive types only", () => {
+    const SortArgs = createEntitySortArgs("Contract", {
+      address: "string",
+      chain_id: "number",
+      metadata: {
+        type: "id",
+        references: {
+          entity: "Metadata",
+          fields: { name: "string" },
